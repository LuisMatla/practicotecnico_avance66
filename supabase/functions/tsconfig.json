{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "types": [],
    "allowJs": true
  },
  "include": ["**/index.ts"],
  "exclude": [
    "node_modules",
    "**/*.md",
    "**/*.sh",
    "**/COPIAR_Y_PEGAR.md",
    "**/README.md",
    "**/DEPLOY.sh"
  ]
}
